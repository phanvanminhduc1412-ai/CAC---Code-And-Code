<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CAC - Code And Code</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0f1a;
            --surface: rgba(20, 28, 45, 0.7);
            --surface-solid: #141c2d;
            --primary: #4da8da;
            --green: #4caf84;
            --yellow: #e6b84c;
            --red: #e0556a;
            --text: #e0e6f0;
            --text-secondary: #a0b0c8;
            --border: rgba(255, 255, 255, 0.08);
            --shadow: 0 8px 32px rgba(0,0,0,0.35);
            --radius: 16px;
            --transition: 0.3s;
            --glass-bg: rgba(20,28,48,0.55);
            --glass-blur: blur(18px);
        }
        .light-mode { --bg: #f0f4f8; --surface: rgba(255,255,255,0.75); --surface-solid: #fff; --text: #1a1f2e; --text-secondary: #556078; --border: rgba(0,0,0,0.08); --glass-bg: rgba(255,255,255,0.6); }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Poppins',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; background-image:radial-gradient(ellipse at 20% 20%, rgba(77,168,218,0.08), transparent 55%), radial-gradient(ellipse at 80% 70%, rgba(76,175,132,0.06), transparent 55%); background-attachment:fixed; transition:background 0.5s; }
        ::-webkit-scrollbar { width:6px; } ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.2); border-radius:10px; }
        .header { position:sticky; top:0; z-index:100; background:var(--glass-bg); backdrop-filter:var(--glass-blur); border-bottom:1px solid var(--border); padding:12px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; box-shadow:0 2px 20px rgba(0,0,0,0.2); }
        .header-brand h1 { font-size:2rem; font-weight:800; background:linear-gradient(135deg,#4da8da,#4caf84); -webkit-background-clip:text; -webkit-text-fill-color:transparent; animation:logoPulse 3s infinite; }
        @keyframes logoPulse { 0%,100%{filter:brightness(1)}50%{filter:brightness(1.3)} }
        .user-info { font-weight:600; font-size:0.9rem; background:rgba(255,255,255,0.05); padding:6px 14px; border-radius:20px; border:1px solid var(--border); }
        .server-status-badge { padding:7px 14px; border-radius:20px; font-size:0.8rem; font-weight:600; animation:statusGlow 2s infinite; border:1px solid transparent; }
        .server-status-badge.preparing { background:rgba(230,184,76,0.15); color:#e6b84c; }
        .server-status-badge.open { background:rgba(76,175,132,0.15); color:#4caf84; }
        .server-status-badge.closed { background:rgba(224,85,106,0.15); color:#e0556a; }
        @keyframes statusGlow { 0%,100%{box-shadow:0 0 8px currentColor}50%{box-shadow:0 0 20px currentColor} }
        .btn { padding:10px 18px; border-radius:25px; border:none; cursor:pointer; font-weight:600; font-size:0.85rem; display:inline-flex; align-items:center; gap:6px; transition:0.3s; background:transparent; color:var(--primary); border:2px solid var(--primary); }
        .btn:hover { background:rgba(77,168,218,0.1); }
        .btn-primary { background:linear-gradient(135deg,#4da8da,#4caf84); color:#fff; border:none; }
        .btn-success { background:linear-gradient(135deg,#4caf84,#3a8b66); color:#fff; border:none; }
        .btn-danger { background:linear-gradient(135deg,#e0556a,#c0392b); color:#fff; border:none; }
        .sidebar { width:260px; background:var(--glass-bg); backdrop-filter:var(--glass-blur); border-right:1px solid var(--border); padding:20px 0; }
        .sidebar-nav a { display:flex; align-items:center; gap:10px; padding:12px 24px; color:var(--text-secondary); text-decoration:none; border-left:3px solid transparent; }
        .sidebar-nav a:hover, .sidebar-nav a.active { color:var(--text); background:rgba(255,255,255,0.04); border-left-color:var(--primary); }
        .content-area { flex:1; padding:28px; overflow-y:auto; }
        .card { background:var(--glass-bg); backdrop-filter:var(--glass-blur); border:1px solid var(--border); border-radius:var(--radius); padding:24px; margin-bottom:20px; box-shadow:var(--shadow); }
        .table-wrapper { overflow-x:auto; } table { width:100%; border-collapse:collapse; } th,td { padding:12px 16px; border-bottom:1px solid var(--border); } th { color:var(--text-secondary); font-size:0.78rem; text-transform:uppercase; }
        .rank-badge { display:inline-flex; width:36px; height:36px; border-radius:50%; align-items:center; justify-content:center; font-weight:700; } .rank-1{background:linear-gradient(135deg,#ffd700,#ffb800);color:#1a1a1a;} .rank-2{background:linear-gradient(135deg,#c0c0c0,#a0a0a0);} .rank-3{background:linear-gradient(135deg,#cd7f32,#b87333);color:#fff;}
        .hidden { display:none!important; }
        .problem-item { display:flex; align-items:center; padding:14px 18px; border-radius:10px; background:rgba(255,255,255,0.02); margin-bottom:8px; cursor:pointer; border:1px solid transparent; } .problem-item:hover { background:rgba(255,255,255,0.05); border-color:var(--border); }
        .code-editor-wrapper { display:flex; border-radius:10px; overflow:hidden; background:#0d1117; } .line-numbers { padding:14px 10px; background:#161b22; color:#6e7681; font-family:'JetBrains Mono',monospace; } .code-textarea { flex:1; padding:14px 16px; background:#0d1117; color:#e6edf3; font-family:'JetBrains Mono',monospace; border:none; outline:none; min-height:300px; line-height:1.6; }
        .toast-container { position:fixed; top:20px; right:20px; z-index:300; } .toast { padding:14px 20px; border-radius:10px; color:#fff; animation:slideInRight 0.4s; } @keyframes slideInRight{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
        @media (max-width:768px){ .sidebar{position:fixed;bottom:0;left:0;right:0;width:100%;border-top:1px solid var(--border);flex-direction:row;overflow-x:auto;} .sidebar-nav{display:flex;} .content-area{padding-bottom:80px;} }
    </style>
</head>
<body>
    <div class="toast-container" id="toastContainer"></div>
    <header class="header">
        <div class="header-brand"><h1>CAC</h1><span class="header-subtitle">Code And Code</span><span class="server-status-badge hidden" id="headerStatusBadge"></span></div>
        <div class="header-actions">
            <span class="user-info hidden" id="userDisplayName"></span>
            <button class="btn" onclick="toggleTheme()">🌓</button>
            <button class="btn hidden" id="btnLogout" onclick="logout()">🚪</button>
        </div>
    </header>
    <div class="main-container" style="display:flex;">
        <aside class="sidebar hidden" id="sidebar">
            <ul class="sidebar-nav">
                <li><a href="javascript:void(0)" data-view="adminDashboard" class="active" onclick="switchAdminView('adminDashboard',event)">📊 Dashboard</a></li>
                <li><a href="javascript:void(0)" data-view="adminUsers" onclick="switchAdminView('adminUsers',event)">👥 Tài khoản</a></li>
                <li><a href="javascript:void(0)" data-view="adminProblems" onclick="switchAdminView('adminProblems',event)">📝 Bài tập</a></li>
                <li><a href="javascript:void(0)" data-view="adminSubmissions" onclick="switchAdminView('adminSubmissions',event)">📨 Bài nộp</a></li>
                <li><a href="javascript:void(0)" data-view="adminServer" onclick="switchAdminView('adminServer',event)">⚙️ Server</a></li>
                <li><a href="javascript:void(0)" data-view="adminHistory" onclick="switchAdminView('adminHistory',event)">📋 Lịch sử</a></li>
            </ul>
        </aside>
        <main class="content-area" id="contentArea">
            <!-- Login -->
            <div id="viewLogin" class="view">
                <div style="max-width:420px;margin:40px auto;" class="card">
                    <h3>🔐 Đăng nhập</h3>
                    <div class="form-group"><label>Tên đăng nhập</label><input class="form-input" id="loginUsername"></div>
                    <div class="form-group"><label>Mật khẩu</label><input type="password" class="form-input" id="loginPassword"></div>
                    <button class="btn btn-primary" style="width:100%;justify-content:center;" onclick="handleLogin()">Đăng nhập</button>
                    <p style="text-align:center;margin-top:14px;"><a href="javascript:void(0)" onclick="showView('viewRegister')">Đăng ký</a></p>
                </div>
            </div>
            <!-- Register -->
            <div id="viewRegister" class="view hidden">
                <div style="max-width:420px;margin:40px auto;" class="card">
                    <h3>📝 Đăng ký</h3>
                    <div class="form-group"><label>Tên đăng nhập</label><input class="form-input" id="regUsername"></div>
                    <div class="form-group"><label>Mật khẩu</label><input type="password" class="form-input" id="regPassword"></div>
                    <div class="form-group"><label>Họ tên</label><input class="form-input" id="regFullname"></div>
                    <button class="btn btn-primary" style="width:100%;" onclick="handleRegister()">Đăng ký</button>
                    <p style="text-align:center;margin-top:14px;"><a href="javascript:void(0)" onclick="showView('viewLogin')">Đăng nhập</a></p>
                </div>
            </div>
            <!-- User Home -->
            <div id="viewUserHome" class="view hidden">
                <div class="card" id="leaderboardCard">
                    <h3>🏆 Bảng xếp hạng</h3><div id="serverStatusInfo"></div>
                    <table><thead><tr><th>Hạng</th><th>Username</th><th>Điểm chi tiết</th><th>Tổng</th></tr></thead><tbody id="leaderboardBody"></tbody></table>
                </div>
                <div id="userProblemsSection" class="card hidden"><h3>📋 Bài tập</h3><div id="userProblemList"></div></div>
                <div id="userOwnScores" class="card hidden"><h3>📊 Điểm của bạn</h3><div id="userOwnScoresContent"></div></div>
            </div>
            <!-- Code Submit -->
            <div id="viewCodeSubmit" class="view hidden">
                <div class="card">
                    <h3>💻 <span id="submitProblemTitle"></span></h3>
                    <p id="submitProblemDesc" style="color:var(--text-secondary);"></p>
                    <div id="submitClosedWarning" class="hidden" style="color:#e0556a;"></div>
                    <div class="code-editor-wrapper">
                        <div class="line-numbers" id="lineNumbers">1</div>
                        <textarea class="code-textarea" id="codeTextarea" placeholder="// Code của bạn..."></textarea>
                    </div>
                    <div style="margin-top:16px;display:flex;gap:10px;">
                        <button class="btn btn-success" onclick="handleSubmitCode()">📤 Nộp bài</button>
                        <button class="btn" onclick="goBackToHome()">📋 Về danh sách</button>
                    </div>
                </div>
            </div>
            <!-- Admin views... (same structure as before, but with event.preventDefault() in links) -->
            <div id="viewAdminDashboard" class="view hidden">...</div>
            <div id="viewAdminUsers" class="view hidden">...</div>
            <div id="viewAdminProblems" class="view hidden">...</div>
            <div id="viewAdminSubmissions" class="view hidden">...</div>
            <div id="viewAdminServer" class="view hidden">...</div>
            <div id="viewAdminHistory" class="view hidden">...</div>
        </main>
    </div>

    <script>
        const STORAGE_KEY = 'cac_data_v5';
        function getData() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch(e) { return null; } }
        function saveData(data) { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

        let appData = (() => {
            let d = getData();
            if (!d) {
                d = { users:[{username:'admin',password:'14122011',fullname:'ADMIN',role:'admin',status:'approved',totalScore:0,banned:false}], sessions:[], submissions:[], serverState:'closed', currentSessionId:null, theme:'dark' };
                saveData(d);
            }
            // Migration: ensure all users have banned property
            d.users.forEach(u => { if (u.banned === undefined) u.banned = false; });
            if (!d.users.find(u => u.username === 'admin')) d.users.push({username:'admin',password:'14122011',fullname:'ADMIN',role:'admin',status:'approved',totalScore:0,banned:false});
            if (!d.sessions) d.sessions = [];
            if (!d.submissions) d.submissions = [];
            if (d.theme === 'light') document.body.classList.add('light-mode');
            saveData(d);
            return d;
        })();

        let currentUser = null, currentView = 'viewLogin', currentAdminSubView = 'adminDashboard', currentSubmitProblem = null;

        window.addEventListener('storage', (e) => { if (e.key === STORAGE_KEY && e.newValue) { appData = JSON.parse(e.newValue); if (currentView) refreshCurrentView(); } });

        function toggleTheme() { document.body.classList.toggle('light-mode'); appData.theme = document.body.classList.contains('light-mode') ? 'light' : 'dark'; saveData(appData); showToast('Đã đổi giao diện','info'); }
        function showToast(msg, type='info') { const t = document.createElement('div'); t.className=`toast toast-${type}`; t.textContent=msg; document.getElementById('toastContainer').appendChild(t); setTimeout(()=>{ t.style.opacity='0'; setTimeout(()=>t.remove(),400); },3000); }
        function showView(view) { document.querySelectorAll('.view').forEach(v=>v.classList.add('hidden')); document.getElementById(view).classList.remove('hidden'); currentView = view; document.getElementById('sidebar').classList.toggle('hidden', !(currentUser?.role==='admin')); refreshCurrentView(); }
        function switchAdminView(sub, event) { event.preventDefault(); currentAdminSubView = sub; showView('view'+sub.charAt(0).toUpperCase()+sub.slice(1)); document.querySelectorAll('.sidebar-nav a').forEach(a=>a.classList.remove('active')); document.querySelector(`.sidebar-nav a[data-view="${sub}"]`)?.classList.add('active'); }
        function refreshCurrentView() { appData = getData() || appData; updateHeaderStatus(); switch(currentView) { case 'viewUserHome': renderUserHome(); break; case 'viewCodeSubmit': renderCodeSubmit(); break; case 'viewAdminDashboard': renderAdminDashboard(); break; case 'viewAdminUsers': renderAdminUsers(); break; case 'viewAdminProblems': renderAdminProblems(); break; case 'viewAdminSubmissions': renderAdminSubmissions(); break; case 'viewAdminServer': renderAdminServer(); break; case 'viewAdminHistory': renderAdminHistory(); break; } }
        function updateHeaderStatus() { const badge = document.getElementById('headerStatusBadge'); const s = appData.serverState; badge.classList.remove('preparing','open','closed','hidden'); if(s==='preparing') { badge.textContent='🟡 Chuẩn bị'; badge.classList.add('preparing'); } else if(s==='open') { badge.textContent='🟢 Mở'; badge.classList.add('open'); } else { badge.textContent='🔴 Đóng'; badge.classList.add('closed'); } badge.classList.toggle('hidden', !currentUser && s!=='open'); document.getElementById('btnLogout').classList.toggle('hidden', !currentUser); document.getElementById('userDisplayName').classList.toggle('hidden', !currentUser); if(currentUser) document.getElementById('userDisplayName').innerHTML = `👤 Coder: <strong>${escapeHtml(currentUser.fullname||currentUser.username)}</strong>`; }

        function handleLogin() { /* ... same as before ... */ }
        // ... (rest of the unchanged functions: handleLogin, logout, handleRegister, renderUserHome, etc.)
        // Keep all previous functions unchanged, just add the event parameter in switchAdminView call and update links.

        // Insert the rest of your existing code (render functions, etc.) exactly as before, but ensure that all <a href="#" onclick="..."> in the HTML part have been replaced with <a href="javascript:void(0)" onclick="..."> and where onclick calls switchAdminView, pass event and use event.preventDefault().

        // In the Admin Users section, add a button to reload data manually:
        function reloadData() { appData = getData() || initData(); showToast('Đã tải lại dữ liệu từ LocalStorage','info'); renderAdminUsers(); }
        // Add this button in renderAdminUsers(): <button class="btn btn-sm" onclick="reloadData()">🔄 Tải lại</button>

        // Important: In handleLogin, check for banned user.
        function handleLogin() {
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value.trim();
            if (!username || !password) return showToast('Vui lòng nhập đầy đủ','error');
            const user = appData.users.find(u=>u.username===username && u.password===password);
            if (!user) return showToast('Sai thông tin','error');
            if (user.status==='pending') return showToast('Tài khoản chưa được duyệt','warning');
            if (user.banned) return showToast('Bạn đã bị ban khỏi cuộc thi','error');
            currentUser = {username:user.username, role:user.role, fullname:user.fullname};
            showToast(`Chào ${user.fullname}`,'success');
            document.getElementById('loginUsername').value=''; document.getElementById('loginPassword').value='';
            if (user.role==='admin') switchAdminView('adminDashboard', new Event('click'));
            else showView('viewUserHome');
        }

        // ... paste the rest of your functions (unchanged) ...
        // Ensure that renderAdminUsers includes the reload button.
    </script>
</body>
</html>